# Telegram API (получить на my.telegram.org)
API_ID=
API_HASH=

# номер телефона аккаунта userbot
PHONE=

# username бота-источника запросов (без @)
# для теста: ваш тестовый бот
# для прода: GorbushkinBot
SOURCE_BOT=

# ID чата с прайс-листом
# для теста: ID тестового чата
# для прода: ID реального чата
PRICE_CHAT_ID=

# username заказчика для уведомлений (без @)
# бот будет присылать сюда запросы которые не нашёл в прайсе
OWNER_USERNAME=

# === только для тестирования ===
# токен тестового бота (от @BotFather)
BOT_TOKEN=
# chat ID аккаунта юзербота (узнать через @userinfobot)
USERBOT_CHAT_ID=
